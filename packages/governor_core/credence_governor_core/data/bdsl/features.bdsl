; ============================================================
; features.bdsl — the brain's sensory vocabulary.
;
; Each (feature ...) form declares one feature the brain
; expects to receive in tool-proposed events. The body's
; startup verifies every declared feature has a registered
; extractor and exits with an error if any is missing.
;
; Pass 1 declares the features but does not condition on them
; (the posterior is global). Pass 2 will use them in the
; structure-learning machinery; declaring them now means the
; observation log already contains the data Pass 2 will want.
; ============================================================

(define tool-name-space
  (space :finite read write edit bash exec process apply_patch grep find ls other))

(define wd-relative-space
  (space :finite project-root subdirectory outside-project no-path))

(define rep-count-space
  (space :finite rep-0 rep-1 rep-2 rep-3plus))

; Argument-level repetition: how many recent calls were the SAME (tool, args).
; This is the loop signal — a re-run of the *same* call — which tool-level
; repetition (rep-count) cannot isolate. Added after the offline eval showed the
; tool/parent/rep feature set cannot catch real waste; see eval/results/FINDINGS.md.
(define ident-count-space
  (space :finite ident-0 ident-1 ident-2 ident-3plus))

(define time-since-user-space
  (space :finite lt-30s lt-2m lt-10m gt-10m))

(define parent-tool-name-space
  (space :finite read write edit bash exec process apply_patch grep find ls other none))

(define features
  (list
    (feature tool-name                    tool-name-space)
    (feature working-directory-relative   wd-relative-space)
    (feature parent-tool-call-name        parent-tool-name-space)
    (feature recent-repetition-count      rep-count-space)
    (feature recent-identical-call-count  ident-count-space)
    (feature time-since-last-user-message time-since-user-space)))

; ── Safety features (multi-outcome governance) ──────────────────────────
; The harm posterior conditions on these to estimate P(unsafe|X) — the taint-flow
; family validated on ATBench-Claw (eval/results/SAFETY_INGREDIENTS.md): the
; discriminator is whether a consequential sink carries a value that originated in
; UNTRUSTED content. SEPARATE from the waste `features` above (a different outcome, a
; frozen posterior). The brain folds H·P(unsafe|X) into the decision only when
; `harm-cost > 0` (utility.bdsl) AND the body emits these features; otherwise the
; governor is waste-only, exactly as before. The body computes them causally (a token
; taints a call only if seen in untrusted content BEFORE it).

(define action-class-space
  (space :finite read-only local-write delete exec external-send credential-access cross-boundary other))

; Graded taint-flow: does a consequential sink carry an untrusted-sourced value?
(define taint-flow-space
  (space :finite none tainted-sink tainted-external-target))

; Provenance of the most-external value reaching the sink (M2). NOT a gate — a
; feature the posterior conditions on: an in-workspace read (read-own) is benign
; provenance the brain learns to discount, while web/email/marker stay high-harm.
; Most-external first (safety.py:_SOURCE_EXTERNALITY); `none` when nothing taints.
(define taint-source-space
  (space :finite
    web browser email message command-network marker
    read-external command-external local-external
    read-unknown command-unknown local-unknown
    read-own command-own local-own
    none))

; Where the action's destination sits (M3): a curl to 127.0.0.1 is structurally an
; external-send but its target is `internal`, so the posterior learns external-send
; x internal is benign while external-send x external stays the unambiguous-harm extreme.
(define target-externality-space
  (space :finite external internal none))

; Does this action execute an imperative verb issued by untrusted content?
(define injected-imperative-space
  (space :finite no yes))

; Did a credential-access call precede an external-send (the two-step exfil chain)?
(define cred-exfil-chain-space
  (space :finite no yes))

; ── Coding-threat-matched safety features (M4, coding-threat-matched harm model) ──
; docs/coding-threat-matched-harm-model.md §3. The provenance trio (taint-source,
; taint-flow, injected-imperative) + cred-exfil-chain are kept; the assistant-shaped
; action-class / target-externality are REPLACED by coding's actual threat axes:
; capability (coding-action-class), WHERE the action lands (target-sensitivity — the
; axis the assistant model lacked), and a refined egress (egress-destination). Trained
; coding-native (build_harm_brain.build_coding: declared red-team n1 + captured-benign
; n0; ATBench retired for this body). action-class-space / target-externality-space
; stay DEFINED above — extract_safety still emits them and other callers read them —
; but are no longer in the conditioned set.

; WHERE a filesystem action lands — the axis the assistant model lacked. Orthogonal
; to coding-action-class's WHAT: a local-edit is benign on project-source, alarming on a
; credential-store. Closes the recall hole (write ~/.ssh/authorized_keys and CI-workflow
; backdoors extracted as benign source edits on the assistant model).
(define target-sensitivity-space
  (space :finite project-source project-config credential-store system-privileged external-unknown none))

; Refines target-externality with the dev-vs-exfil splits the binary internal/
; external axis blurred: a curl to 127.0.0.1 is loopback (benign dev), a fetch
; from pypi.org is external-allowlisted, an unknown host is external-unknown.
(define egress-destination-space
  (space :finite none loopback internal-net external-allowlisted external-unknown))

; Coding-native action classes (destructive / package-mutation / privilege-op)
; the assistant model never needed. Structural — tool name or command head.
(define coding-action-class-space
  (space :finite read-only local-edit destructive external-send credential-access package-mutation privilege-op exec other))

; The conditioned harm 7-tuple. Order MUST match config.HARM["feature_names"] and
; build_harm_brain._CTX_KEYS (boot asserts the committed brain agrees).
(define safety-features
  (list
    (feature coding-action-class coding-action-class-space)
    (feature target-sensitivity  target-sensitivity-space)
    (feature egress-destination  egress-destination-space)
    (feature taint-source        taint-source-space)
    (feature taint-flow          taint-flow-space)
    (feature injected-imperative injected-imperative-space)
    (feature cred-exfil-chain    cred-exfil-chain-space)))
